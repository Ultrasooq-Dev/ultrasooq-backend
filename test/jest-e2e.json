{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": "(e2e-spec|load-test\\.spec)\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "diagnostics": false }]
  },
  "setupFilesAfterEnv": ["<rootDir>/jest.setup.ts"],
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1"
  },
  "forceExit": true,
  "roots": ["<rootDir>", "<rootDir>/performance"]
}
