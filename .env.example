# ==============================================================================
# Ultrasooq Backend - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ==============================================================================

# --- Database ---
LOCAL_DATABASE_URL=postgresql://postgres:password@localhost:5432/ultrasooq
DATABASE_URL=postgresql://postgres:password@localhost:5432/ultrasooq

# --- JWT Authentication ---
JWT_SECRET=your-strong-random-secret-here
JWT_EXPIRY=1h

# --- Server ---
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:4001,http://localhost:3001,http://localhost:3000
MAX_REQUEST_SIZE=10mb
FRONTEND_SERVER=http://localhost:4001

# --- OTP ---
OTP_EXPIRY_MINUTES=5

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- AWS S3 (File Uploads) ---
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_BUCKET=your-s3-bucket-name
AWS_LOCATION=us-east-1

# --- Stripe (Payment Processing) ---
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key

# --- Paymob (Payment Gateway - MENA Region) ---
PAYMOB_API_KEY=your-paymob-api-key
PAYMOB_SECRET_KEY=your-paymob-secret-key
PAYMOB_PUBLIC_KEY=your-paymob-public-key
PAYMOB_HMAC_SECRET=your-paymob-hmac-secret
PAYMOB_IFRAME_ID=your-paymob-iframe-id
PAYMOB_INTEGRATION_ID=your-paymob-integration-id
PAYMOB_MOTO_INTEGRATION_ID=your-paymob-moto-integration-id
PAYMOB_USERNAME=your-paymob-username
PAYMOB_PASSWORD=your-paymob-password
PAYMOB_WEBHOOK_URL=https://your-backend-domain.com/payment/paymob-webhook
PAYMOB_PAYMENT_LINK_WEBHOOK_URL=https://your-backend-domain.com/payment/paymob-webhook-createPaymentLink
PAYMOB_EMI_WEBHOOK_URL=https://your-backend-domain.com/payment/webhook-PaymentForEMI
PAYMOB_EMI_RECURRING_WEBHOOK_URL=https://your-backend-domain.com/payment/webhookForEMI
FRONTEND_CHECKOUT_URL=http://localhost:4001/checkout-complete

# --- AmwalPay (Payment Gateway - Oman) ---
AMWALPAY_MID=your-amwalpay-merchant-id
AMWALPAY_TID=your-amwalpay-terminal-id
AMWALPAY_SECURE_HASH_KEY=your-amwalpay-secure-hash-key
AMWALPAY_CURRENCY_ID=512
AMWALPAY_WEBHOOK_URL=https://your-backend-domain.com/payment/amwalpay-webhook

# --- Delivery Management ---
DELIVERY_AUTO_CONFIRM_DAYS=7
PICKUP_EXPIRY_DAYS=5

# --- SendGrid (Email) ---
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_SENDER=noreply@yourdomain.com

# --- Better Auth ---
# ============================================================================
# REQUIRED IN PRODUCTION
# ----------------------------------------------------------------------------
# BETTER_AUTH_SECRET   : MUST be set to a cryptographically random 32+ byte
#                        value. Generate with: openssl rand -base64 32
# BETTER_AUTH_URL      : MUST be the public origin of the API (e.g.
#                        https://api.ultrasooq.com). Defaults to localhost in
#                        dev — leaving the localhost value in production will
#                        break OAuth redirects, password-reset links, and
#                        cookie issuance.
# CORS_ORIGINS         : MUST list every frontend origin that may call the
#                        API (comma-separated). An empty value blocks ALL
#                        cross-origin browser requests.
# FRONTEND_SERVER      : Frontend origin used for invitation/passkey URLs
#                        and WebAuthn rpID derivation.
# COOKIE_DOMAIN        : Optional. Set to the parent domain (e.g.
#                        ".ultrasooq.com") to share auth cookies across
#                        subdomains. Leave blank for host-only cookies.
# GOOGLE_CLIENT_ID     : Required only if Google OAuth is enabled.
# GOOGLE_CLIENT_SECRET : Required only if Google OAuth is enabled.
# SENDGRID_API_KEY     : Required for transactional email (verification, OTP,
#                        password reset, invitations).
# SENDGRID_SENDER      : Verified sender address used as the From: header.
# ============================================================================
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
# Comma-separated User.id values granted admin permissions via the Better Auth
# `admin` plugin regardless of the User.role column. Leave empty for none.
BETTER_AUTH_ADMIN_USER_IDS=
# Google OAuth — uses ${BETTER_AUTH_URL}/api/auth/callback/google as redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Frontend origin used for invitation/passkey URLs and rpID derivation
FRONTEND_SERVER=http://localhost:4001
# Cookie domain for auth cookies. Leave empty for host-only cookies (default).
# Set to a leading-dot parent domain (e.g. ".ultrasooq.com") in production to
# share session cookies across subdomains (app., admin., api., etc.).
COOKIE_DOMAIN=

# --- BrowserBase (Cloud Browser for Scraping) ---
BROWSERBASE_API_KEY=your-browserbase-api-key
BROWSERBASE_PROJECT_ID=your-browserbase-project-id
USE_BROWSERBASE=false

# --- OpenRouter (AI - Product Categorization) ---
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct,deepseek/deepseek-chat-v3
OPENROUTER_VISION_MODEL=openai/gpt-4.1-mini
APP_URL=http://localhost:3000

# --- Puppeteer (Scraper) ---
PUPPETEER_EXECUTABLE_PATH=
LOCAL_SCRAPER_URL=http://localhost:4000

# --- Dev/Test ---
ENABLE_TEST_AUTH_BYPASS=false
