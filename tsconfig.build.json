// tsconfig.build.json — Production build TypeScript configuration.
//
// @intent   Extends the root tsconfig.json but excludes test files and output
//           directories from the compilation, producing a clean production build.
// @notes
//   - Excludes: node_modules, test directory, dist output, and all .spec.ts test files.
//   - Used by `nest build` (see package.json scripts).
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // Disable .d.ts emission for the app build. Better Auth's inferred return
    // type references internal zod sub-paths (better-auth/node_modules/zod/v4/core)
    // that aren't directly importable, causing TS2742 portability errors when
    // declaration generation is on. The backend is deployed as a runtime app —
    // no consumer imports its .d.ts files.
    "declaration": false,
    "incremental": false
  },
  "exclude": ["node_modules", "test", "dist", "scraper-mcp", "**/*spec.ts"]
}
